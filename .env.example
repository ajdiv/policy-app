# Client (Expo) environment. Copy to ".env".
# Base URL of the backend. Use your computer's LAN IP (not localhost) when
# testing on a physical phone, e.g. http://192.168.1.203:3000
EXPO_PUBLIC_API_URL=http://localhost:3000

# Google SSO (web): the "Web application" OAuth client ID from Google Cloud Console.
# Must match GOOGLE_CLIENT_ID in server/.env. Sign-in is hidden until this is set.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

