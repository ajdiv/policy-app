# Copy this file to ".env" and fill in your keys.
# Get a Congress.gov key (free, instant): https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=

# Get a Gemini key (free tier): https://aistudio.google.com/app/apikey
# Used for BOTH answer generation and embeddings.
GEMINI_API_KEY=

# Port the backend listens on.
PORT=3000

# Google SSO. Create a "Web application" OAuth client at
# https://console.cloud.google.com (APIs & Services > Credentials).
# Use the SAME Web client ID here and as EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID in the root .env.
GOOGLE_CLIENT_ID=
# Secret used to sign app session tokens. Use a long random string in production.
JWT_SECRET=

# Models (override only if you know what you're doing).
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Ingestion knobs (Phase 1).
# Comma-separated Federal Register president slugs to pull presidential actions for
# (executive orders, memoranda, proclamations, determinations).
INGEST_PRESIDENTS=donald-trump
# Optional safety ceiling on presidential actions ingested per president.
# Leave unset to ingest the president's full document set (the default).
# INGEST_MAX_EOS=2000

# House roll-call vote ingestion (Phase 2).
INGEST_CONGRESSES=118,119
INGEST_SESSIONS=1,2
# Max roll calls to ingest in total (each pulls ~435 member votes). Raise for fuller coverage.
INGEST_MAX_ROLLCALLS=400
